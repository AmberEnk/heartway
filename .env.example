# PostgreSQL — use Vercel Postgres, Neon, or Supabase
DATABASE_URL="postgresql://user:password@host:5432/heartway?sslmode=require"

# Generate: openssl rand -base64 32
AUTH_SECRET="replace-with-a-long-random-secret"
AUTH_URL="http://localhost:3000"

# Comma-separated admin emails for blog CMS and moderation
ADMIN_EMAILS="you@example.com"

# Public app URL (no trailing slash)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Matchmaking launch (LA-first). Swipe discover off until enough users.
NEXT_PUBLIC_LAUNCH_CITY="Los Angeles"
NEXT_PUBLIC_MATCHMAKING_MODE="true"
NEXT_PUBLIC_DISCOVER_ENABLED="false"
